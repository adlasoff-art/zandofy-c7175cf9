# Zandofy Backend — Variables d'environnement
# Copier en .env et renseigner les valeurs

# App
APP_ENV=development
# En production : APP_ENV=production (obligatoire)
DEBUG=true
API_PREFIX=/api
# CORS — En production : liste exacte des origines (séparées par des virgules, sans espaces après)
# Exemple prod : CORS_ORIGINS=https://zandofy.com,https://www.zandofy.com
CORS_ORIGINS=

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret (Project Settings > API) — pour accepter les tokens Supabase du frontend (support, etc.)
SUPABASE_JWT_SECRET=

# JWT — En production : générer une clé forte (ex. openssl rand -hex 32). Ne jamais utiliser "change-me-in-production".
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60

# SMTP (emails transactionnels)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@zandofy.com
SMTP_TLS=true

# Kelpay (passerelle paiement)
KELPAY_MERCHANT_CODE=
KELPAY_TOKEN=
KELPAY_WEBHOOK_SECRET=
KELPAY_BASE_URL=https://api.kelpay.com

# Storage (factures PDF)
STORAGE_BUCKET=invoices
SUPABASE_STORAGE_URL=

# Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME=image/jpeg,image/png,image/webp,application/pdf

# Sitemap & reset password link
SITE_BASE_URL=https://zandofy.com

# OpenAI (recherche par image GPT-4o)
OPENAI_API_KEY=
