# Variables exposées au build (préfixe VITE_). Ne pas committer de secrets.
# Copier en .env et renseigner les valeurs. DATABASE_URL ne doit jamais être ici (backend uniquement).

# Supabase (auth, realtime, edge functions)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Backend FastAPI (support, visual-search, etc.)
# Dev / preview : http://localhost:8000
# Production : URL publique de l'API (ex. https://api.zandofy.com ou https://zandofy.com/api)
# Ne jamais mettre de secret backend ici (uniquement VITE_*).
VITE_API_URL=http://localhost:8000
