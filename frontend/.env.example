# Variables exposées au build (préfixe VITE_). Ne pas committer de secrets.
# Copier en .env.local pour le dev local.

# Supabase (auth, REST, realtime, edge functions)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Canonical site URL (SEO canonical, OG) — must match Cloudflare primary domain
VITE_SITE_URL=https://zandofy.com

# Vercel Edge (meta-injector for Facebook/WhatsApp/Google bots) — same values as above
SITE_URL=https://zandofy.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: Meta Sharing Debugger fb:app_id warning
FACEBOOK_APP_ID=

# Supabase Edge Functions secrets (Dashboard → Edge Functions → Secrets, not VITE_)
# EMBEDDING_API_KEY=   # Hugging Face token for CLIP visual search indexing
# OPENAI_API_KEY=      # Fallback keyword search in visual-search
